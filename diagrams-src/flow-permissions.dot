digraph G {
  graph [rankdir=LR, bgcolor="transparent", pad=0.3, nodesep=0.45, ranksep=0.8, splines=ortho]
  node [shape=rect, style="rounded,filled", fontname="Helvetica", fontsize=13, color="#4fc3ff", fillcolor="#11243c", fontcolor="#e7eefb", margin="0.18,0.12"]
  edge [color="#7bbcff", penwidth=1.7, arrowsize=0.8]

  settings [label="settings.ts"]
  project [label="Project config"]
  flags [label="CLI flags"]
  setup [label="permissionSetup.ts", fillcolor="#14344f"]
  metadata [label="Tool metadata"]
  perms [label="permissions.ts", fillcolor="#14344f"]
  outcomes [label="Allow / Ask / Deny"]

  settings -> setup
  project -> setup
  flags -> setup
  setup -> perms
  metadata -> perms
  perms -> outcomes
}
